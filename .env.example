# Backend
APP_ENV=development
LOG_LEVEL=INFO

# Database. Lokaal mag sqlite, productie gebruikt Postgres (Render geeft je een URL).
DATABASE_URL=sqlite:///./app.db
# Voorbeeld productie:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/db

# CORS-origins (komma-gescheiden)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Scrapers
# Wanneer USE_MOCK_SCRAPERS=true gebruikt de app realistische mockdata
# zodat je geen externe sites hoeft te raken tijdens ontwikkelen.
USE_MOCK_SCRAPERS=true
SCRAPER_INTERVAL_HOURS=24
SCRAPER_USER_AGENT=SupermarktReceptenTool/0.1 (+https://example.com)
SCRAPER_TIMEOUT=20

# Open Food Facts
OPENFOODFACTS_USER_AGENT=SupermarktReceptenTool/0.1 (contact@example.com)
OPENFOODFACTS_BASE_URL=https://world.openfoodfacts.org

# LLM (optioneel)
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_PROVIDER=openai

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
